import { Outlet }       from 'react-router-dom';
import { useAppStore }  from '@/store';
import { Sidebar }      from './Sidebar';
import { Topbar }       from './Topbar';
import { VoicePanel }   from '@/components/voice/VoicePanel';
import { UpgradeModal } from '@/components/voice/UpgradeModal';
import { ToastContainer } from '@/components/ui/Toast';

export function AppShell() {
  const sidebarOpen  = useAppStore((s) => s.sidebarOpen);
  const closeSidebar = useAppStore((s) => s.closeSidebar);

  return (
    <div className="w-full flex" style={{ height: '100dvh', overflow: 'hidden' }}>

      {/* Mobile sidebar overlay */}
      {sidebarOpen && (
        <div
          className="fixed inset-0 z-[99] md:hidden"
          style={{ background: 'rgba(0,0,0,.55)', backdropFilter: 'blur(2px)' }}
          onClick={closeSidebar}
        />
      )}

      {/* Sidebar — fixed on mobile, static on desktop */}
      <div
        className={[
          'fixed top-0 bottom-0 z-[100] md:relative md:left-0',
          'transition-[left] duration-[280ms] ease-[cubic-bezier(.4,0,.2,1)]',
          sidebarOpen ? 'left-0' : 'left-[-280px]',
          'md:flex',
        ].join(' ')}
      >
        <Sidebar />
      </div>

      {/* Main content */}
      <main className="flex-1 flex flex-col overflow-hidden">
        <Topbar />

        {/* Scrollable content area */}
        <div className="flex-1 overflow-y-auto" id="main-area">
          <div className="max-w-7xl mx-auto p-4 md:p-6 pb-8">
            <Outlet />
          </div>
        </div>
      </main>

      {/* Global overlays */}
      <VoicePanel />
      <UpgradeModal />
      <ToastContainer />
    </div>
  );
}
